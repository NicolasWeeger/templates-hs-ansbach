{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Marp: HTML watch (auto-export on save)",
            "type": "shell",
            "command": "marp --watch --html --allow-local-files --input-dir Slides --output Slides/html_Slides",
            "isBackground": true,
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": false,
                "clear": false
            },
            "runOptions": {
                "runOn": "folderOpen"
            },
            "problemMatcher": []
        }
    ]
}
